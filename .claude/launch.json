{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "desktop-dev-server",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd desktop && npm run dev-server"],
      "port": 3178
    },
    {
      "name": "web-dev-server",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd web && npm run start:dev"],
      "port": 9000
    },
    {
      "name": "karma-test-runner",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd desktop && npm run test-app"],
      "port": 9876
    }
  ]
}
